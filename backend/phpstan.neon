includes:
    - ./vendor/larastan/larastan/extension.neon

parameters:

    paths:
        - app/

    # Level 9 is the highest level
    level: 2

    ignoreErrors:
        - '#PHPDoc tag @var#'
        - "#Called 'first' on Laravel collection, but could have been retrieved as a query#"
        
    excludePaths:
        - ./*/*/FileToBeExcluded.php

    checkMissingIterableValueType: false
